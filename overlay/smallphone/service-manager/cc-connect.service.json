{
  "name": "cc-connect",
  "description": "OpenHouse Connect (cc-connect): bridge + management + webhook",
  "provider": "process",
  "command": [
    "/bin/sh",
    "/root/.smallphoneai/bin/openhouse-cc-connect-launcher.sh"
  ],
  "working_dir": "/root/smallphoneai-repos/openhouse-connect",
  "env": {
    "PATH": "/root/.npm-global/bin:/root/.local/node/bin:/root/.opencode/bin:/root/.local/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin:/system/bin:/system/xbin:/data/data/com.termux/files/usr/bin",
    "HOME": "/root",
    "USER": "root",
    "LOGNAME": "root",
    "SHELL": "/bin/bash",
    "XDG_CONFIG_HOME": "/root/.config",
    "XDG_CACHE_HOME": "/root/.cache",
    "XDG_DATA_HOME": "/root/.local/share"
  },
  "runtime": {},
  "restart": {
    "mode": "always",
    "max_retries": 0
  },
  "health": [
    {
      "type": "tcp",
      "address": "127.0.0.1:21010",
      "interval": "30s",
      "timeout": "3s"
    },
    {
      "type": "tcp",
      "address": "127.0.0.1:21020",
      "interval": "30s",
      "timeout": "3s"
    }
  ],
  "enabled": true,
  "tags": [
    "group:local-stack",
    "openhouse-component:cc-connect"
  ]
}
